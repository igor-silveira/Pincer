[gateway]
bind = "loopback"
port = 18789
# auth_token = ""

[agent]
model = "claude-sonnet-4-20250514"
# api_key_env = ""
# base_url = ""
# auth_header = ""
# fallback_models = ["gpt-4o", "gemini-2.0-flash"]
max_context_tokens = 128000
max_tool_iterations = 25
tool_approval = "ask"
# tool_concurrency = 1
# tool_timeout = "30s"
# system_prompt = ""

[agent.retry]
# max_attempts = 3
# strategies = ["retry", "simplify"]
# cooldown_ms = 1000

[agent.checkpoint]
# enabled = false
# token_threshold = 80000
# retention_hours = 24

[agent.verification]
# enabled = false
# confidence_threshold = 0.8
# max_attempts = 3
# gates = ["tool_call", "final_answer"]

[sandbox]
mode = "process"
network_policy = "deny"
max_timeout = "5m"
# allowed_paths = []
# read_only_paths = []

[memory]
immutable_keys = ["identity", "core_values"]
max_versions = 100
# vector_search = false

[store]
driver = "sqlite"
# dsn = ".pincer/pincer.db"

[log]
level = "info"
format = "json"

[mcp]
enabled = true

[[mcp.servers]]
name = "playwright"
command = "npx"
args = ["@playwright/mcp@latest"]
# url = ""
# env = { KEY = "value" }
# enabled = true

[tracing]
# enabled = false
# endpoint = ""

[skills]
# dir = ""
# allow_unsigned = false

[credentials]
# master_key_env = "PINCER_MASTER_KEY"

[soul]
# path = "soul.toml"

[browser]
# enabled = false
# headless = false
# idle_timeout = "5m"

# Channel adapters. Uncomment and configure as needed.

[channels.telegram]
enabled = true
token_env = "TELEGRAM_BOT_TOKEN"
# token = ""
# allow_list = []

# [channels.discord]
# enabled = true
# token_env = "DISCORD_BOT_TOKEN"
# token = ""
# allow_list = []

